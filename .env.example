# ─── Docker Compose env ──────────────────────────────────────────────────────
# Copy this file to `.env` (same folder) and fill in your real values.
# `docker compose` reads `.env` automatically.

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=flowdesk_local_dev

# ── JWT signing secret for the dashboard's admin auth ───────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=REPLACE_WITH_RANDOM_BASE64

# ── Retell AI ───────────────────────────────────────────────────────────────
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx
RETELL_API_BASE=https://api.retellai.com

# ── Google Calendar OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/oauth/callback
GOOGLE_CALENDAR_ID=your-account@gmail.com

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── n8n webhook base URL (used when n8n calls back into itself) ─────────────
# For local dev keep it as-is. When you expose n8n to the internet via ngrok
# or a tunnel, set this to your public URL so n8n's webhook UI shows the right
# address to paste into Retell.
N8N_WEBHOOK_URL=http://localhost:5678/
