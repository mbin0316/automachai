# ─── FlowDesk Server — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Session ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# JWT signing secret for admin auth cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=REPLACE_WITH_RANDOM_BASE64

# Admin user store (JSON file, swap for a real DB later)
ADMINS_DB_PATH=./data/admins.json

# ── Retell AI ──────────────────────────────────────────────────────────────────
# Found at: https://beta.retellai.com/dashboard → Settings → API Keys
RETELL_API_KEY=key_32f0c6b4e1c7c07e32a89dec04fb
RETELL_API_BASE=https://api.retellai.com

# ── Google OAuth2 (for Calendar) ───────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client ID
# Scopes needed: calendar.readonly, calendar.events
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/oauth/callback
# Calendar ID to read appointments from (usually the Gmail address)
GOOGLE_CALENDAR_ID=talkinghead001@gmail.com

# ── Database (Postgres) ────────────────────────────────────────────────────────
# Production: a Neon connection string (pick Singapore region for MY latency).
# Local dev:  a local Postgres URL, with DATABASE_SSL=false.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_SSL=true

# ── CORS allowed origins ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
